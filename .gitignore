# =============================================================================
# LASC OS — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Arquivos temporários
# -----------------------------------------------------------------------------
*.tmp
*.log
*.cache
*~
*.bak

# -----------------------------------------------------------------------------
# Backups locais (arquivos grandes, não versionados)
# -----------------------------------------------------------------------------
backups/
*.tar.gz
*.tar.bz2
*.zip

# -----------------------------------------------------------------------------
# Arquivos de sistema operacional
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDEs e editores
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
.project
.classpath

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.env

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# pmbootstrap e Alpine Linux
# -----------------------------------------------------------------------------
.local/
chroot_*/
.pmbootstrap/

# -----------------------------------------------------------------------------
# Imagens de disco (arquivos muito grandes)
# -----------------------------------------------------------------------------
*.img
*.qcow2
*.iso
*.vmdk
*.vdi

# -----------------------------------------------------------------------------
# Dados sensíveis
# -----------------------------------------------------------------------------
*.key
*.pem
*.cert
*.p12
secrets/
.env.local
.env.production
